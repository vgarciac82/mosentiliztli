# ─────────────────────────────────────────────────────────────────────────────
# Docker Private Registry — Environment Variables Template
#
# USAGE:
#   Option A (recommended): bash scripts/setup.sh  → auto-generates secrets
#   Option B (manual):      cp .env.example .env  → edit with your values
#
# SECURITY: Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── General ───────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info

# Registry FQDN — used in nginx server_name and TLS certificate CN/SAN
# Replace with your actual domain (or keep localhost for testing)
REGISTRY_DOMAIN=registry.example.com

# Network binding address for nginx ports (0.0.0.0 = all interfaces)
# Set to a specific IP to restrict access, e.g. 10.0.0.1
BIND_ADDRESS=0.0.0.0

# ── Registry HTTP Secret ───────────────────────────────────────────────────────
# Random secret for internal cookie/state signing — MUST be unique per deployment
# Generate: openssl rand -base64 32
REGISTRY_HTTP_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── Initial Admin User ────────────────────────────────────────────────────────
# Stored in auth/htpasswd (bcrypt-hashed) — created by scripts/setup.sh
REGISTRY_ADMIN_USER=admin
REGISTRY_ADMIN_PASSWORD=CHANGE_ME_use_strong_password_min_16_chars

# ── MinIO (S3-compatible storage backend) ─────────────────────────────────────
# Root credentials for MinIO server
# Generate password: openssl rand -base64 32
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# Bucket name for registry data
MINIO_BUCKET=docker-registry

# ── Prometheus ────────────────────────────────────────────────────────────────
# How long to retain metrics data
PROMETHEUS_RETENTION=30d
