# =============================================================================
# GitHub Actions — Build, Push & Scan with Private Registry
#
# Required GitHub Secrets (Settings → Secrets and variables → Actions):
#   REGISTRY_HOST      e.g. registry.example.com
#   REGISTRY_USER      e.g. admin
#   REGISTRY_PASSWORD
#   REGISTRY_CA_CERT   (optional) PEM content of self-signed CA cert
#
# Usage: copy/rename to .github/workflows/build-push.yml in your app repo
# =============================================================================

name: Build, Push & Scan

on:
  push:
    branches: [main]
    tags:     ["v*.*.*"]
  pull_request:
    branches: [main]

env:
  REGISTRY: ${{ secrets.REGISTRY_HOST }}
  IMAGE:    ${{ secrets.REGISTRY_HOST }}/${{ github.repository }}

jobs:
  build-push-scan:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write   # required for uploading SARIF results

    steps:
      # ── Checkout ────────────────────────────────────────────────────────────
      - name: Checkout source
        uses: actions/checkout@v4

      # ── Trust self-signed cert (remove if using Let's Encrypt) ──────────────
      - name: Trust private registry certificate
        if: ${{ secrets.REGISTRY_CA_CERT != '' }}
        run: |
          sudo mkdir -p /etc/docker/certs.d/${{ env.REGISTRY }}
          echo "${{ secrets.REGISTRY_CA_CERT }}" \
            | sudo tee /etc/docker/certs.d/${{ env.REGISTRY }}/ca.crt
          sudo systemctl reload docker

      # ── Login ────────────────────────────────────────────────────────────────
      - name: Login to private registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ secrets.REGISTRY_USER }}
          password: ${{ secrets.REGISTRY_PASSWORD }}

      # ── Docker Buildx ────────────────────────────────────────────────────────
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      # ── Extract metadata (tags + labels) ─────────────────────────────────────
      - name: Extract Docker metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{ env.IMAGE }}
          tags: |
            type=sha,prefix=,format=short
            type=ref,event=branch
            type=semver,pattern={{version}}
            type=semver,pattern={{major}}.{{minor}}

      # ── Build & Push ──────────────────────────────────────────────────────────
      - name: Build and push
        id: build
        uses: docker/build-push-action@v5
        with:
          context: .
          push:    ${{ github.event_name != 'pull_request' }}
          tags:    ${{ steps.meta.outputs.tags }}
          labels:  ${{ steps.meta.outputs.labels }}
          cache-from: type=registry,ref=${{ env.IMAGE }}:buildcache
          cache-to:   type=registry,ref=${{ env.IMAGE }}:buildcache,mode=max

      # ── Vulnerability Scan (Trivy) ────────────────────────────────────────────
      - name: Scan image for vulnerabilities
        uses: aquasecurity/trivy-action@master
        with:
          image-ref:    "${{ env.IMAGE }}@${{ steps.build.outputs.digest }}"
          severity:     "HIGH,CRITICAL"
          exit-code:    "1"          # fail CI on HIGH/CRITICAL
          format:       "sarif"
          output:       "trivy-results.sarif"
          timeout:      "10m"
        env:
          TRIVY_USERNAME: ${{ secrets.REGISTRY_USER }}
          TRIVY_PASSWORD: ${{ secrets.REGISTRY_PASSWORD }}

      # ── Upload SARIF to GitHub Security tab ───────────────────────────────────
      - name: Upload Trivy results to GitHub Security
        uses: github/codeql-action/upload-sarif@v3
        if:   always()   # upload even if scan found CVEs
        with:
          sarif_file: trivy-results.sarif

      # ── Logout ───────────────────────────────────────────────────────────────
      - name: Logout from registry
        if:   always()
        run:  docker logout ${{ env.REGISTRY }}
