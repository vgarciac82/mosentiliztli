# =============================================================================
# GitLab CI/CD — Build, Push & Scan with Private Registry
#
# Required CI/CD variables (set in GitLab → Settings → CI/CD → Variables):
#   REGISTRY_HOST      e.g. registry.example.com
#   REGISTRY_USER      e.g. admin
#   REGISTRY_PASSWORD  (mark as Masked + Protected)
#
# Usage: copy/rename to .gitlab-ci.yml in your application repository
# =============================================================================

stages:
  - build
  - push
  - scan
  - deploy

variables:
  REGISTRY_HOST: registry.example.com          # override in CI/CD variables
  IMAGE_NAME:    $REGISTRY_HOST/$CI_PROJECT_PATH
  IMAGE_TAG:     $CI_COMMIT_SHA
  IMAGE_LATEST:  $REGISTRY_HOST/$CI_PROJECT_PATH:latest

# ── Build ──────────────────────────────────────────────────────────────────────
build:
  stage: build
  image: docker:27
  services:
    - docker:27-dind
  variables:
    DOCKER_TLS_CERTDIR: "/certs"
  before_script:
    - docker info
  script:
    - docker build
        --cache-from $IMAGE_LATEST
        --label "org.opencontainers.image.revision=$CI_COMMIT_SHA"
        --label "org.opencontainers.image.created=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        --label "org.opencontainers.image.source=$CI_PROJECT_URL"
        -t $IMAGE_NAME:$IMAGE_TAG
        -t $IMAGE_LATEST
        .
    - docker save $IMAGE_NAME:$IMAGE_TAG | gzip > image.tar.gz
  artifacts:
    paths:
      - image.tar.gz
    expire_in: 1 hour

# ── Push ───────────────────────────────────────────────────────────────────────
push:
  stage: push
  image: docker:27
  services:
    - docker:27-dind
  variables:
    DOCKER_TLS_CERTDIR: "/certs"
  dependencies:
    - build
  script:
    - docker load < image.tar.gz
    # Trust self-signed certificate (remove if using Let's Encrypt)
    - mkdir -p /etc/docker/certs.d/$REGISTRY_HOST
    - echo "$REGISTRY_CA_CERT" > /etc/docker/certs.d/$REGISTRY_HOST/ca.crt  # optional: set REGISTRY_CA_CERT var if self-signed
    - echo "$REGISTRY_PASSWORD" | docker login -u "$REGISTRY_USER" --password-stdin $REGISTRY_HOST
    - docker push $IMAGE_NAME:$IMAGE_TAG
    - docker push $IMAGE_LATEST
    - docker logout $REGISTRY_HOST
  only:
    - main
    - tags

# ── Vulnerability Scan (Trivy) ─────────────────────────────────────────────────
scan:
  stage: scan
  image: aquasec/trivy:latest
  variables:
    TRIVY_NO_PROGRESS: "true"
    TRIVY_CACHE_DIR: ".trivycache"
  script:
    - trivy image
        --severity HIGH,CRITICAL
        --exit-code 1
        --format table
        --timeout 10m
        $IMAGE_NAME:$IMAGE_TAG
  cache:
    paths:
      - .trivycache/
  allow_failure: false   # set to true to warn without blocking deploy
  dependencies:
    - push
  only:
    - main
    - tags

# ── (Optional) Scan and produce SARIF report for GitLab Security Dashboard ────
scan-sarif:
  stage: scan
  image: aquasec/trivy:latest
  script:
    - trivy image
        --severity MEDIUM,HIGH,CRITICAL
        --format sarif
        --output trivy-report.sarif
        $IMAGE_NAME:$IMAGE_TAG
  artifacts:
    reports:
      sast: trivy-report.sarif
    expire_in: 30 days
  allow_failure: true
  only:
    - main
