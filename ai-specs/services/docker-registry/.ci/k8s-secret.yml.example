# =============================================================================
# Kubernetes — imagePullSecret for the private registry
#
# Step 1: Create the secret (run once per namespace)
#   kubectl create secret docker-registry private-registry-cred \
#     --docker-server=registry.example.com \
#     --docker-username=admin \
#     --docker-password=<your-password> \
#     --docker-email=ops@example.com \
#     --namespace=default
#
# Step 2: (optional) Store self-signed CA cert in a ConfigMap and mount it,
#         OR add it to the node's trusted CAs:
#   sudo cp registry.crt /usr/local/share/ca-certificates/private-registry.crt
#   sudo update-ca-certificates
#   sudo systemctl restart containerd
#
# Step 3: Reference the secret in your workloads (examples below)
# =============================================================================

---
# ── Example Pod using the private registry ─────────────────────────────────
apiVersion: v1
kind: Pod
metadata:
  name: example-pod
  namespace: default
spec:
  containers:
    - name: app
      image: registry.example.com/myapp:1.0
      ports:
        - containerPort: 8080
  # Reference the imagePullSecret created in Step 1
  imagePullSecrets:
    - name: private-registry-cred

---
# ── Example Deployment ─────────────────────────────────────────────────────
apiVersion: apps/v1
kind: Deployment
metadata:
  name: example-deployment
  namespace: default
spec:
  replicas: 2
  selector:
    matchLabels:
      app: example
  template:
    metadata:
      labels:
        app: example
    spec:
      containers:
        - name: app
          image: registry.example.com/myapp:1.0
          ports:
            - containerPort: 8080
          resources:
            requests:
              memory: "64Mi"
              cpu:    "50m"
            limits:
              memory: "128Mi"
              cpu:    "200m"
      imagePullSecrets:
        - name: private-registry-cred

---
# ── Attach imagePullSecret to the default ServiceAccount ──────────────────
# Avoids having to add imagePullSecrets to every Pod spec in the namespace.
# Apply once per namespace.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: default
  namespace: default
imagePullSecrets:
  - name: private-registry-cred

---
# ── (Optional) CronJob to rotate the imagePullSecret before it expires ─────
# Useful when using time-limited tokens instead of static passwords.
# Requires: kubectl in the container + RBAC permissions.
apiVersion: batch/v1
kind: CronJob
metadata:
  name: registry-secret-refresh
  namespace: default
spec:
  # Run every 23 hours (before typical 24h token expiry)
  schedule: "0 */23 * * *"
  jobTemplate:
    spec:
      template:
        spec:
          serviceAccountName: default
          containers:
            - name: secret-refresh
              image: bitnami/kubectl:latest
              env:
                - name: REGISTRY_HOST
                  value: "registry.example.com"
                - name: REGISTRY_USER
                  valueFrom:
                    secretKeyRef:
                      name: registry-admin-cred
                      key: username
                - name: REGISTRY_PASSWORD
                  valueFrom:
                    secretKeyRef:
                      name: registry-admin-cred
                      key: password
              command:
                - /bin/sh
                - -c
                - |
                  kubectl create secret docker-registry private-registry-cred \
                    --docker-server=$REGISTRY_HOST \
                    --docker-username=$REGISTRY_USER \
                    --docker-password=$REGISTRY_PASSWORD \
                    --dry-run=client -o yaml | kubectl apply -f -
          restartPolicy: OnFailure
